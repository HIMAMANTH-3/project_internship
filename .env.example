# Environment Variables - Copy to .env and fill in your values

# ─── Node Environment ──────────────────────────────────────────────────────
NODE_ENV=development

# ─── Server ────────────────────────────────────────────────────────────────
PORT=5000

# ─── AI Model Configuration ────────────────────────────────────────────────
# Choose one or both (Gemini takes priority if both set)

# Google Gemini API Key
# Get your key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Key
# Get your key: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ─── Database Configuration ────────────────────────────────────────────────
# Leave empty to use local SQLite (default)
# For PostgreSQL (Supabase, Render, etc):
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ─── Rate Limiting ────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30

# ─── JWT Secret (auto-generated, but can be overridden) ───────────────────
JWT_SECRET=your_jwt_secret_here_change_in_production

# ─── Frontend URL (for CORS) ──────────────────────────────────────────────
# Development: Leave empty (localhost:5173/5174 auto-added)
# Production on Vercel:
FRONTEND_URL=https://your-app.vercel.app
