PORT=5000
NODE_ENV=development

# --- Database ---
# Option 1: PostgreSQL (Supabase or local)
# DATABASE_URL=postgresql://user:password@host:5432/dbname
# If DATABASE_URL is not set, the app will use a local SQLite file automatically.

# --- AI Model (choose one or both, Gemini takes priority) ---
GEMINI_API_KEY=your_gemini_api_key_here
# OPENAI_API_KEY=your_openai_api_key_here

# --- Rate Limiting ---
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=30
